# Supabase 프로젝트 설정 (Supabase Dashboard > Project Settings > API에서 확인)
SUPABASE_URL=https://your-project-ref.supabase.co

# 크롤러/배치 스크립트(서버 환경)에서는 RLS를 우회할 수 있는 service_role 키 사용을 권장합니다.
# service_role 키는 절대 브라우저/클라이언트 코드나 공개 저장소에 노출하지 마세요.
SUPABASE_KEY=your-service-role-key

# Gemini API 키 (Google AI Studio > aistudio.google.com/apikey 에서 카드 등록 없이 무료 발급)
# 기사 3줄 요약 + 카테고리 분류(scripts/summarize-articles.ts)에 사용된다.
GEMINI_API_KEY=your-gemini-api-key

# (선택) 요약/분류에 사용할 Gemini 모델. 지정하지 않으면 코드 기본값(gemini-2.5-flash) 사용.
# gemini-2.0-flash는 2026-06-01부로 서비스 종료(deprecated)되어 사용할 수 없다.
# 무료 티어에서 사용 가능한 모델/한도는 https://aistudio.google.com/rate-limit 에서 확인.
# GEMINI_SUMMARIZE_MODEL=gemini-2.5-flash

# (선택) 한 번 실행할 때 요약할 최대 기사 수. 지정하지 않으면 20.
# SUMMARIZE_BATCH_LIMIT=20

# (선택) 기사 처리 사이 최소 간격(ms). 지정하지 않으면 13000(13초).
# Gemini 무료 티어는 모델별로 분당 요청 수(RPM) 제한이 있다(예: gemini-2.5-flash 무료 티어는
# 분당 5회 = 12초에 1회). 이 간격보다 짧게 설정하면 요약 도중 "429 RESOURCE_EXHAUSTED"
# (요청 한도 초과) 에러가 자주 날 수 있다. 사용 중인 모델의 무료 티어 한도는
# https://aistudio.google.com/rate-limit 에서 확인.
# GEMINI_MIN_INTERVAL_MS=13000

# 사용법:
#   1. 이 파일을 .env 로 복사한다: cp .env.example .env
#   2. 위 값을 실제 Supabase / Gemini 값으로 채운다.
#   .env 파일은 .gitignore에 포함되어 있어 git에 커밋되지 않는다.
